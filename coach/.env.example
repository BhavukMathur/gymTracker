# Provider: auto | openai | gemini
#   auto   — use OpenAI if OPENAI_API_KEY is set, else Gemini (GOOGLE_API_KEY / GEMINI_API_KEY)
#   openai — require OPENAI_API_KEY
#   gemini — require GEMINI_API_KEY or GOOGLE_API_KEY
LLM_PROVIDER=auto

# OpenAI (recommended if Gemini quota is exhausted)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (Google AI Studio)
GEMINI_API_KEY=
# Optional alias for GEMINI_API_KEY:
# GOOGLE_API_KEY=

GEMINI_MODEL=gemini-2.0-flash

# Spring Boot API base (tools call this with the user JWT)
BACKEND_URL=http://127.0.0.1:8080

# Must match the dashboard monthly goal in the React app (default 20)
MONTHLY_GOAL_DAYS=20
